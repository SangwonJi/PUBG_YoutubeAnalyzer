# ──────────────────────────────────────────────
# PUBG Weibo Analyzer - Environment Variables
# ──────────────────────────────────────────────

# 웨이보 대상 계정 (기본: 和平精英 공식)
WEIBO_UID=7095404909
WEIBO_ACCOUNT_NAME=和平精英

# 웨이보 쿠키 (선택: 레이트 리밋 완화용)
# 브라우저에서 m.weibo.cn 로그인 후 Cookie 값을 복사
WEIBO_COOKIE=

# 요청 간 딜레이 (초, 기본: 3.0)
WEIBO_REQUEST_DELAY=3.0

# 게시물당 최대 댓글 수집 수 (기본: 200)
WEIBO_MAX_COMMENTS_PER_POST=200

# GPT API (콜라보 분류용)
GPT_API_KEY=your_openai_api_key_here
GPT_MODEL=gpt-4o-mini

# 데이터베이스 경로
DB_PATH=./data/pubg_weibo.db

# 출력 디렉토리
OUTPUT_DIR=./output

# 클라우드 업로드 (선택)
CLOUD_API_KEY=
CLOUD_UPLOAD_URL=
